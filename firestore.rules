rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll([
        'nick','nickNorm','email','emailNorm','passwordHash','createdAtMs'
      ]);
      allow update: if true;
      allow delete: if false;
    }
    
    match /emailIndex/{emailId} {
      allow read, write: if true;
    }
    
    match /pendingRegistrations/{nickId} {
      allow read, write: if true;
    }
    
    match /pendingResets/{nickId} {
      allow read, write: if true;
    }
    
    match /roles/{username} {
      allow read, write: if true;
    }
    
    match /messages/{msgId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['author','text','ts'])
                    && request.resource.data.author is string
                    && request.resource.data.author.size() > 0
                    && request.resource.data.author.size() < 50;
      allow update: if true;
      allow delete: if true;
    }
    
    match /chats/{chatId} {
      allow read, write: if true;
      match /messages/{msgId} {
        allow read, write: if true;
      }
    }
    
    match /presence/{docId} {
      allow read, write: if true;
    }
    
    match /typing/{userId} {
      allow read, write: if true;
    }
    
    match /meta/{docId} {
      allow read, write: if true;
    }
    
    match /notifications/{id} {
      allow read, write: if true;
    }
    
    match /announcements/{docId} {
      allow read, write: if true;
    }

    match /olympScores/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
